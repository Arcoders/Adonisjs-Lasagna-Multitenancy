    "src/commands/main.ts",
    "src/events/index.ts",
    "src/exceptions/index.ts",
    "src/extensions/request.ts",
    "src/health/index.ts",
    "src/jobs/index.ts",
    "src/middleware/index.ts",
    "src/models/adapters/index.ts",
