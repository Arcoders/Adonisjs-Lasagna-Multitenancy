# ─── App ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3333
HOST=127.0.0.1
LOG_LEVEL=info
APP_KEY=replace-me-with-32-random-chars-aaaa

# ─── Multitenancy ────────────────────────────────────────────────
TENANT_HEADER_KEY=x-tenant-id
APP_DOMAIN=localhost

# ─── PostgreSQL (matches docker-compose.yml) ──────────────────────
DB_HOST=127.0.0.1
DB_PORT=55432
DB_USER=app
DB_PASSWORD=app
DB_DATABASE=lasagna_demo

# ─── Redis (matches docker-compose.yml) ───────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=56379

QUEUE_REDIS_HOST=127.0.0.1
QUEUE_REDIS_PORT=56379
QUEUE_REDIS_DB=1

CACHE_REDIS_HOST=127.0.0.1
CACHE_REDIS_PORT=56379
CACHE_REDIS_DB=2

# ─── Backups (optional — disabled by default) ────────────────────
BACKUP_STORAGE_PATH=./storage/backups

# ─── S3 (optional — leave disabled unless you want to test S3 path) ─
BACKUP_S3_ENABLED=false
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=us-east-1
BACKUP_S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Demo admin auth (header-based fake) ─────────────────────────
DEMO_ADMIN_TOKEN=demo-admin-token-change-me

# ─── Mail (MailCatcher in dev/test, swap for real SMTP in prod) ──
# Web UI: http://localhost:1080  |  JSON API: http://localhost:1080/messages
MAILCATCHER_HOST=127.0.0.1
MAILCATCHER_PORT=1025
MAIL_FROM_ADDRESS=demo@example.test
MAIL_FROM_NAME=Demo Multitenancy
