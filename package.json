{
  "name": "@adonisjs-lasagna/multitenancy",
  "version": "2.0.0-beta.0",
  "description": "Multi-tenancy for AdonisJS 7 with pluggable isolation drivers (schema/database/row-scoping), connection pooling, circuit breaking, queues, and satellite features",
  "type": "module",
  "license": "MIT",
  "author": "Ismael Haytam Tanane",
  "homepage": "https://github.com/Arcoders/Adonisjs-Lasagna-Multitenancy#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arcoders/Adonisjs-Lasagna-Multitenancy.git"
  },
  "bugs": {
    "url": "https://github.com/Arcoders/Adonisjs-Lasagna-Multitenancy/issues"
  },
  "keywords": [
    "adonisjs",
    "adonis",
    "multitenancy",
    "multi-tenant",
    "saas",
    "postgresql",
    "schema-based"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "workspaces": [
    "examples/api"
  ],
  "files": [
    "build",
    "stubs"
  ],
  "exports": {
    ".": "./build/src/index.js",
    "./adapters": "./build/src/models/adapters/index.js",
    "./base-models": "./build/src/models/base/index.js",
    "./models/satellites": "./build/src/models/satellites/index.js",
    "./middleware": "./build/src/middleware/index.js",
    "./services": "./build/src/services/index.js",
    "./events": "./build/src/events/index.js",
    "./jobs": "./build/src/jobs/index.js",
    "./types": "./build/src/types/index.js",
    "./exceptions": "./build/src/exceptions/index.js",
    "./extensions/request": "./build/src/extensions/request.js",
    "./providers/multitenancy_provider": "./build/src/providers/multitenancy_provider.js",
    "./commands": "./build/src/commands/main.js",
    "./testing": "./build/src/testing/index.js",
    "./health": "./build/src/health/index.js",
    "./admin": "./build/src/admin/index.js"
  },
  "typesVersions": {
    "*": {
      "adapters": [
        "./build/src/models/adapters/index.d.ts"
      ],
      "base-models": [
        "./build/src/models/base/index.d.ts"
      ],
      "models/satellites": [
        "./build/src/models/satellites/index.d.ts"
      ],
      "middleware": [
        "./build/src/middleware/index.d.ts"
      ],
      "services": [
        "./build/src/services/index.d.ts"
      ],
      "events": [
        "./build/src/events/index.d.ts"
      ],
      "jobs": [
        "./build/src/jobs/index.d.ts"
      ],
      "types": [
        "./build/src/types/index.d.ts"
      ],
      "exceptions": [
        "./build/src/exceptions/index.d.ts"
      ],
      "extensions/request": [
        "./build/src/extensions/request.d.ts"
      ],
      "providers/multitenancy_provider": [
        "./build/src/providers/multitenancy_provider.d.ts"
      ],
      "commands": [
        "./build/src/commands/main.d.ts"
      ],
      "testing": [
        "./build/src/testing/index.d.ts"
      ],
      "health": [
        "./build/src/health/index.d.ts"
      ],
      "admin": [
        "./build/src/admin/index.d.ts"
      ]
    }
  },
  "adonisjs": {
    "configure": "./build/configure.js",
    "commands": [
      "./build/src/commands/main.js"
    ]
  },
  "main": "./build/src/index.js",
  "types": "./build/src/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('fs').cpSync('src/commands/commands.json','build/src/commands/commands.json')\"",
    "typecheck": "tsc --noEmit",
    "test": "tsx bin/test.ts",
    "test:integration": "npm run build && tsx bin/test.integration.ts"
  },
  "peerDependencies": {
    "@adonisjs/core": "^7.0.0",
    "@adonisjs/lucid": "^22.0.0",
    "@adonisjs/queue": "^0.6.0",
    "@adonisjs/redis": "^10.0.0",
    "@aws-sdk/client-s3": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-s3": {
      "optional": true
    }
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "bentocache": "^1.0.0",
    "bullmq": "^5.0.0",
    "luxon": "^3.0.0",
    "opossum": "^9.0.0"
  },
  "prettier": "@adonisjs/prettier-config",
  "devDependencies": {
    "@adonisjs/assembler": "^8.4.0",
    "@adonisjs/core": "^7.0.0",
    "@adonisjs/eslint-config": "^2.0.0-beta.6",
    "@adonisjs/lucid": "^22.0.0",
    "@adonisjs/prettier-config": "^1.4.0",
    "@adonisjs/queue": "^0.6.0",
    "@adonisjs/redis": "^10.0.0",
    "@adonisjs/tsconfig": "^1.4.0",
    "@japa/api-client": "^3.2.1",
    "@japa/assert": "^4.0.1",
    "@japa/plugin-adonisjs": "^5.0.0",
    "@japa/runner": "^4.2.0",
    "@types/luxon": "^3.0.0",
    "@types/node": "^22.0.0",
    "@types/opossum": "^8.1.9",
    "eslint": "^9.20.0",
    "prettier": "^3.4.2",
    "reflect-metadata": "^0.2.0",
    "tsx": "^4.19.0",
    "typescript": "~5.7"
  }
}
