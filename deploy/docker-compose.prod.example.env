# Copy this to .env (or .env.production) and fill in real values.
# Never commit the populated file.

# AdonisJS app key — generate with `node ace generate:key`
APP_KEY=

# Postgres primary
DB_USER=app
DB_PASSWORD=replace-me
DB_NAME=lasagna_prod

# Streaming replication user. Created on the primary by init-replica.sh.
POSTGRES_REPLICATION_PASSWORD=replace-me-too

# Redis
REDIS_PASSWORD=replace-me-redis
